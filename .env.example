# 🧵 THE TAILOR : Configuration (Client)

# --- YUMI HUB CONFIGURATION ---
# L'URL du Hub Yumi local ou distant
VITE_YUMI_HUB_URL=http://localhost:4000/api/verify

# L'ID unique généré dans le Hub Admin pour "The Tailor"
# OBTENIR CET ID SUR : http://localhost:4000/admin/logiciels
VITE_YUMI_PROJECT_ID=REMPLACER_PAR_UUID_DU_HUB

# --- APP CONFIGURATION ---
VITE_APP_NAME="The Tailor"
VITE_VERSION="1.0.0-MVP"

# --- DATABASE ---
# Chemin relatif ou absolu pour SQLite (géré par Tauri Plugin Sql)
DATABASE_URL="sqlite://the_tailor_prod.db"
